{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateEvent",
  "description": "Schema for creating a new event. Server generates id, creatorUid, invitee statuses, and timestamps.",
  "type": "object",
  "properties": {
    "title": {
      "$ref": "base.schema.json#/properties/title"
    },
    "description": {
      "$ref": "base.schema.json#/properties/description"
    },
    "location": {
      "$ref": "base.schema.json#/properties/location"
    },
    "startTime": {
      "$ref": "base.schema.json#/properties/startTime"
    },
    "endTime": {
      "$ref": "base.schema.json#/properties/endTime"
    },
    "rrule": {
      "$ref": "base.schema.json#/properties/rrule"
    },
    "inviteeUids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 50,
      "description": "UIDs to invite (server sets their status to pending)"
    }
  },
  "required": ["title", "startTime"],
  "additionalProperties": false
}
