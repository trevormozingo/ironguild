{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BaseReaction",
  "description": "Base reaction schema. One reaction per user per post.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Reaction ID (MongoDB ObjectId as string)"
    },
    "postId": {
      "type": "string",
      "description": "Post ID (MongoDB ObjectId as string)"
    },
    "authorUid": {
      "type": "string",
      "description": "Firebase UID of the user who reacted"
    },
    "type": {
      "type": "string",
      "enum": [
        "strong",
        "fire",
        "heart",
        "smile",
        "laugh",
        "thumbsup",
        "thumbsdown",
        "angry"
      ],
      "description": "Emoji reaction type"
    }
  },
  "required": ["postId", "authorUid", "type"],
  "additionalProperties": false
}
