{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PrivateProfile",
  "description": "Full profile view for the authenticated owner. Includes all fields.",
  "type": "object",
  "properties": {
    "username": {
      "$ref": "base.schema.json#/properties/username"
    },
    "displayName": {
      "$ref": "base.schema.json#/properties/displayName"
    },
    "bio": {
      "$ref": "base.schema.json#/properties/bio"
    },
    "birthday": {
      "$ref": "base.schema.json#/properties/birthday"
    },
    "status": {
      "$ref": "base.schema.json#/properties/status"
    },
    "location": {
      "$ref": "base.schema.json#/properties/location"
    }
  },
  "required": ["username", "displayName", "status"],
  "additionalProperties": false
}
