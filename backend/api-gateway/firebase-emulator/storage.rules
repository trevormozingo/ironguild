rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      // Reads are public — profile photos and post media need to be
      // viewable by anyone (including unauthenticated Image components).
      allow read: if true;
      // Writes are restricted — the backend uses the Admin SDK which
      // bypasses rules, so this blocks any direct client uploads.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
