{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BaseEvent",
  "description": "Base event schema containing all event fields",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Event ID (MongoDB ObjectId as string)"
    },
    "authorUid": {
      "type": "string",
      "description": "Firebase UID of the event creator"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Event title"
    },
    "description": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2000,
      "description": "Optional event description"
    },
    "location": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 500,
      "description": "Location (gym name, address, etc.)"
    },
    "startTime": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 start time"
    },
    "endTime": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 end time (optional)"
    },
    "rrule": {
      "type": ["string", "null"],
      "maxLength": 500,
      "pattern": "^FREQ=(DAILY|WEEKLY|MONTHLY|YEARLY)",
      "description": "iCal RRULE recurrence string (e.g. FREQ=WEEKLY;BYDAY=MO;UNTIL=20260601T000000Z)"
    },
    "invitees": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string",
            "description": "Firebase UID of the invitee"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "accepted", "declined"],
            "description": "RSVP status"
          }
        },
        "required": ["uid", "status"],
        "additionalProperties": false
      },
      "maxItems": 50,
      "description": "Invited users with RSVP status"
    }
  }
}
