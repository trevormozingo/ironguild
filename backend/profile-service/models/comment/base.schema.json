{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BaseComment",
  "description": "Base comment schema.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Comment ID (MongoDB ObjectId as string)"
    },
    "postId": {
      "type": "string",
      "description": "Post ID (MongoDB ObjectId as string)"
    },
    "authorUid": {
      "type": "string",
      "description": "Firebase UID of the comment author"
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Comment text"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    }
  },
  "required": ["id", "postId", "authorUid", "body", "createdAt"],
  "additionalProperties": false
}
