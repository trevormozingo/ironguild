{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreatePost",
  "description": "Schema for creating a new post. Server generates id, authorUid, and timestamps. A post must contain at least one content field.",
  "type": "object",
  "properties": {
    "title": {
      "$ref": "base.schema.json#/properties/title"
    },
    "body": {
      "$ref": "base.schema.json#/properties/body"
    },
    "media": {
      "$ref": "base.schema.json#/properties/media"
    },
    "workout": {
      "$ref": "base.schema.json#/properties/workout"
    },
    "bodyMetrics": {
      "$ref": "base.schema.json#/properties/bodyMetrics"
    }
  },
  "minProperties": 1,
  "additionalProperties": false
}
